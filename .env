# Project Mukti — environment variables
# Copy this file to `.env` and fill in real values.

# Required: Google Gemini API key
GOOGLE_API_KEY=

# Optional: pick a different Gemini model (defaults to gemini-1.5-pro)
# Other options: gemini-1.5-flash (faster, cheaper), gemini-2.0-flash-exp
MUKTI_GEMINI_MODEL=gemini-3-flash-preview

# Optional: Twilio credentials for SMS notifications to families
TWILIO_SID=
TWILIO_TOKEN=

# Optional: override default service port
PORT=8000
